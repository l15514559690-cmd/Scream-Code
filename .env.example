# =============================================================================
# 尖叫 Code · 环境变量样板（复制为 .env 后填写；勿将真实密钥提交到 Git）
# =============================================================================
# 说明：多数 LLM 密钥名由 llm_config.json 里对应条目的 api_key_env_name 决定；
#       运行 `python3 -m src.main config` 可交互管理配置与变量名。
# =============================================================================

# -----------------------------------------------------------------------------
# 无 llm_config.json 或未设置 active 模型时的兼容回退（OpenAI 兼容协议）
# -----------------------------------------------------------------------------
BASE_URL=https://api.openai.com/v1
API_KEY=your_openai_compatible_api_key_here
MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# 与仓库示例 llm_config.json.example（复制为 llm_config.json 后）中各模型对应的密钥变量（按需填写）
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DASHSCOPE_API_KEY=your_dashscope_api_key_here
MOONSHOT_API_KEY=your_moonshot_api_key_here
OLLAMA_API_KEY=your_ollama_placeholder_or_empty
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_2_API_KEY=your_minimax_second_profile_api_key_here

# -----------------------------------------------------------------------------
# 通过 config 新增模型时，可能生成其它名称，例如 YOUR_ALIAS_API_KEY；
# 请以 llm_config.json 中该条的 api_key_env_name 为准在 .env 中增设一行。
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# 可选：开发与运行行为
# -----------------------------------------------------------------------------
# 跳过启动时依赖自检与静默 pip（自动化测试等场景）
# SCREAM_SKIP_DEPS_CHECK=1

# 单次用户消息内 LLM↔工具 最大往返轮数：未设置时默认 100；0/unlimited/none/inf = 不限制；正整数为硬上限
# SCREAM_MAX_AGENT_TOOL_ROUNDS=100

# 覆盖工作区根目录（高级用法；读写文件与会话落盘 .port_sessions/ 均相对此目录）
# SCREAM_WORKSPACE_ROOT=/path/to/workspace
